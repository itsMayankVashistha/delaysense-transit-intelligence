# DelaySense - Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# TfL API credentials (get from https://api-portal.tfl.gov.uk/)
TFL_APP_ID=your_tfl_app_id_here
TFL_APP_KEY=your_tfl_app_key_here

# Data collection settings
DB_PATH=data/raw/tfl_arrivals.sqlite
POLL_SECONDS=30

# Model and artifact paths (defaults work for standard repo layout)
MODEL_PATH=app/models/lightgbm_v2_h300_balanced.joblib
BASELINE_TABLE_PATH=app/artifacts/baseline_table.parquet

# API server settings
API_HOST=0.0.0.0
API_PORT=8000

# Frontend settings — change this when deploying to a remote server
FRONTEND_API_URL=http://localhost:8000

# CORS: comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:8501